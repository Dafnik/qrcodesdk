{
  "name": "docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "start": "pnpm run build:packages && astro dev",
    "build": "pnpm run build:packages && pnpm run build:site",
    "build:packages": "pnpm --workspace-root turbo run build --filter=docs... --filter=!docs",
    "build:site": "ASTRO_CACHE_DIR=.astro-cache/build VITE_CACHE_DIR=.vite-cache/build node scripts/with-astro-lock.mjs astro build",
    "preview": "astro preview",
    "check-types": "pnpm run build:packages && ASTRO_CACHE_DIR=.astro-cache/check-types VITE_CACHE_DIR=.vite-cache/check-types node scripts/with-astro-lock.mjs astro check",
    "lint": "eslint astro.config.mjs scripts src --ext .js,.mjs,.ts --max-warnings 0",
    "astro": "astro",
    "clean": "rm -rf .turbo dist .astro .astro-cache .vite-cache .astro-command.lock"
  },
  "dependencies": {
    "@angular/common": "catalog:",
    "@angular/core": "catalog:",
    "@angular/platform-browser": "catalog:",
    "@angular/platform-server": "catalog:",
    "@astrojs/react": "6.0.1",
    "@astrojs/starlight-tailwind": "5.0.0",
    "@expressive-code/plugin-line-numbers": "0.44.0",
    "@qrcodesdk/angular": "workspace:*",
    "@qrcodesdk/core": "workspace:*",
    "@qrcodesdk/react": "workspace:*",
    "@tailwindcss/vite": "4.3.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rxjs": "catalog:",
    "starlight-links-validator": "0.25.2",
    "tailwindcss": "4.3.2",
    "tslib": "catalog:"
  },
  "devDependencies": {
    "@analogjs/astro-angular": "2.6.2",
    "@angular/build": "catalog:",
    "@angular/compiler": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@angular/language-service": "catalog:",
    "@astrojs/check": "0.9.9",
    "@astrojs/starlight": "0.41.1",
    "@repo/eslint-config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "astro": "7.0.3",
    "sharp": "catalog:",
    "typescript": "catalog:"
  }
}
