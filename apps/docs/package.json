{
  "name": "docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "start": "astro dev",
    "build": "ASTRO_CACHE_DIR=.astro-cache/build VITE_CACHE_DIR=.vite-cache/build node scripts/with-astro-lock.mjs astro build",
    "preview": "astro preview",
    "check-types": "ASTRO_CACHE_DIR=.astro-cache/check-types VITE_CACHE_DIR=.vite-cache/check-types node scripts/with-astro-lock.mjs astro check",
    "lint": "eslint astro.config.mjs scripts src --ext .js,.mjs,.ts --max-warnings 0",
    "astro": "astro",
    "clean": "rm -rf .turbo dist .astro .astro-cache .vite-cache .astro-command.lock"
  },
  "dependencies": {
    "@angular/common": "catalog:",
    "@angular/core": "catalog:",
    "@angular/platform-browser": "catalog:",
    "@angular/platform-server": "catalog:",
    "@astrojs/starlight-tailwind": "^5.0.0",
    "@qrcodesdk/angular": "workspace:*",
    "@tailwindcss/vite": "^4.3.2",
    "rxjs": "catalog:",
    "tailwindcss": "^4.3.2",
    "tslib": "catalog:"
  },
  "devDependencies": {
    "@analogjs/astro-angular": "catalog:",
    "@angular/build": "catalog:",
    "@angular/compiler": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@angular/language-service": "catalog:",
    "@astrojs/check": "catalog:",
    "@astrojs/starlight": "catalog:",
    "@repo/eslint-config": "workspace:*",
    "astro": "catalog:",
    "sharp": "catalog:",
    "typescript": "catalog:"
  }
}
