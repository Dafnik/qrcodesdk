---
import {Card} from '@astrojs/starlight/components';
import {AngularPlaygroundPreview} from '../playground/angular/angular-playground-preview.ts';
import {PlaygroundControls} from '../playground/angular/playground-controls.ts';
import QRCodePlaygroundControls from '../playground/qrcode-playground-controls';
import QRCodeReactPlaygroundPreview from '../playground/QRCodeReactPlaygroundPreview';

import {startQrQuerySync} from '../playground/query-sync.ts';

startQrQuerySync({
  debounceMs: 150,
});
---

<section class="not-content w-full min-w-0" aria-label="QR code package playground">
  <div class="grid min-w-0 items-start gap-4 grid-cols-[minmax(0,1.15fr)_minmax(20rem,0.85fr)]">
    <Card title="Configure">
      <div class="grid gap-4">
        <p>Choose a package, output, matrix, and renderer options.</p>

        <PlaygroundControls client:load />
      </div>
    </Card>
    <div class="sticky top-20">
      <Card title="Preview">
        <p>Rendered by the selected framework package.</p>
        <div class="min-h-96 grid content-center">
          <QRCodeReactPlaygroundPreview client:only="react" />
          <AngularPlaygroundPreview client:load />
        </div>
      </Card>
    </div>
  </div>
</section>

<section class="not-content w-full min-w-0" aria-label="QR code package playground">
  <div class="grid min-w-0 items-start gap-4 grid-cols-[minmax(0,1.15fr)_minmax(20rem,0.85fr)]">
    <QRCodePlaygroundControls client:only="react" />
    <section class="qrcode-playground__panel" aria-labelledby="playground-preview-heading">
      <div class="qrcode-playground__section-heading">
        <h2 id="playground-preview-heading">Preview</h2>
        <p>Rendered by the selected framework package.</p>
      </div>
      <div class="qrcode-playground__preview-stage">
        <QRCodeReactPlaygroundPreview client:only="react" />
        <AngularPlaygroundPreview client:load />
      </div>
    </section>
  </div>
</section>
