---
import path from 'node:path';
import {getCollection} from 'astro:content';
import DefaultFooter from '@astrojs/starlight/components/Footer.astro';

const route = Astro.locals.starlightRoute;
const related = route.entry.data.related ?? [];
const docs = await getCollection('docs');

interface ResolvedRelatedPath {
  id: string;
  suffix: string;
}

/**
 * Converts a related page path such as:
 *
 *   ./page-a.md
 *   ../other/page-b.mdx
 *   ../playground.mdx?pkg=angular
 *
 * into an entry ID relative to the current document while preserving its
 * query string and fragment.
 */
function resolveRelated(currentId: string, relatedPath: string): ResolvedRelatedPath {
  const suffixIndex = relatedPath.search(/[?#]/);

  const pathname = suffixIndex === -1 ? relatedPath : relatedPath.slice(0, suffixIndex);

  const suffix = suffixIndex === -1 ? '' : relatedPath.slice(suffixIndex);

  const withoutExtension = pathname.replace(/\.(md|mdx|mdoc)$/i, '');

  let id = path.posix.normalize(path.posix.join(path.posix.dirname(currentId), withoutExtension));

  // Astro/Starlight represents `folder/index.md` as `folder`.
  id = id.replace(/\/index$/, '');
  id = id.replace(/^\.?\//, '');

  return {id, suffix};
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const resolvedRelated = related.flatMap((relatedPath) => {
  const {id, suffix} = resolveRelated(route.entry.id, relatedPath);
  const entry = docs.find((document) => document.id === id);

  if (!entry) {
    return [];
  }

  return [
    {
      source: relatedPath,
      title: entry.data.title ?? id,
      href: `${base}/${entry.id}/${suffix}`,
    },
  ];
});
---

{
  resolvedRelated.length > 0 && (
    <section class="sl-markdown-content">
      <div class="sl-heading-wrapper level-h2" style="margin-top: 1.5em;">
        <h2 id="related-pages">Related pages</h2>
        <a class="sl-anchor-link" href="#related-pages">
          <span aria-hidden="true" class="sl-anchor-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="m12.11 15.39-3.88 3.88a2.52 2.52 0 0 1-3.5 0 2.47 2.47 0 0 1 0-3.5l3.88-3.88a1 1 0 1 0-1.42-1.42l-3.88 3.89a4.48 4.48 0 0 0 6.33 6.33l3.89-3.88a1 1 0 0 0-1.42-1.42m8.58-12.08a4.49 4.49 0 0 0-6.33 0l-3.89 3.88a1 1 0 1 0 1.42 1.42l3.88-3.88a2.52 2.52 0 0 1 3.5 0 2.47 2.47 0 0 1 0 3.5l-3.88 3.88a1 1 0 0 0 0 1.42 1 1 0 0 0 1.42 0l3.88-3.89a4.49 4.49 0 0 0 0-6.33M8.83 15.17a1 1 0 0 0 .71.29 1 1 0 0 0 .71-.29l4.92-4.92a1 1 0 1 0-1.42-1.42l-4.92 4.92a1 1 0 0 0 0 1.42" />
            </svg>
          </span>
          <span class="sr-only" data-pagefind-ignore="">
            Section titled “Related pages”
          </span>
        </a>
      </div>
      <ul>
        {resolvedRelated.map((relatedPage) => (
          <li>
            <a href={relatedPage.href}>{relatedPage.title}</a>
          </li>
        ))}
      </ul>
    </section>
  )
}

<DefaultFooter />
