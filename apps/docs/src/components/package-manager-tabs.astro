---
import {Tabs, TabItem, Code} from '@astrojs/starlight/components';

type PackageManager = 'pnpm' | 'npm' | 'yarn' | 'bun' | 'viteplus';
type PackageManagerMode = 'add' | 'addDev' | 'addGlobal' | 'exec' | 'dlx';

type Props = {
  packages: string[];
  mode: PackageManagerMode;
  command?: string;
  args?: string[];
  syncKey?: string;
};

const {packages, mode, command, args = [], syncKey = 'package-manager'} = Astro.props as Props;

const packageManagers: PackageManager[] = ['npm', 'pnpm', 'viteplus', 'bun', 'yarn'];

function commandFor(packageManager: PackageManager): string {
  const packageList = packages.join(' ');
  const argumentList = args.join(' ');

  if (mode === 'exec') {
    if (command === undefined) {
      throw new Error('PackageManagerTabs requires a command when mode is "exec".');
    }

    return joinCommand([execCommandPrefix(packageManager), command, argumentList]);
  }

  if (mode === 'dlx') {
    if (packageList.length === 0) {
      throw new Error('PackageManagerTabs requires at least one package when mode is "dlx".');
    }

    return joinCommand([dlxCommandPrefix(packageManager), packageList, argumentList]);
  }

  return joinCommand([installCommandPrefix(packageManager, mode), packageList]);
}

function installCommandPrefix(
  packageManager: PackageManager,
  installMode: Exclude<PackageManagerMode, 'exec' | 'dlx'>,
): string {
  if (installMode === 'addDev') {
    if (packageManager === 'npm') {
      return 'npm install -D';
    }

    if (packageManager === 'viteplus') {
      return 'vp add -D';
    }

    return `${packageManager} add -D`;
  }

  if (installMode === 'addGlobal') {
    if (packageManager === 'npm') {
      return 'npm install -g';
    }

    if (packageManager === 'yarn') {
      return 'yarn global add';
    }

    if (packageManager === 'viteplus') {
      return 'vp install -g';
    }

    return `${packageManager} add -g`;
  }

  if (packageManager === 'viteplus') {
    return 'vp add';
  }

  return packageManager === 'npm' ? 'npm install' : `${packageManager} add`;
}

function execCommandPrefix(packageManager: PackageManager): string {
  if (packageManager === 'pnpm') {
    return 'pnpm exec';
  }

  if (packageManager === 'npm') {
    return 'npx';
  }

  if (packageManager === 'bun') {
    return 'bunx';
  }

  if (packageManager === 'viteplus') {
    return 'vp exec';
  }

  return 'yarn';
}

function dlxCommandPrefix(packageManager: PackageManager): string {
  if (packageManager === 'pnpm') {
    return 'pnpm dlx';
  }

  if (packageManager === 'npm') {
    return 'npx';
  }

  if (packageManager === 'bun') {
    return 'bunx';
  }

  if (packageManager === 'viteplus') {
    return 'vp dlx';
  }

  return 'yarn dlx';
}

function joinCommand(parts: string[]): string {
  return parts.filter((part) => part.length > 0).join(' ');
}
---

<Tabs syncKey={syncKey}>
  {
    packageManagers.map((packageManager) => (
      <TabItem label={packageManager}>
        <Code lang="sh" code={commandFor(packageManager)} />
      </TabItem>
    ))
  }
</Tabs>
