---
import { Tabs, TabItem } from '@astrojs/starlight/components';
import {Code} from 'astro/components';

const { code } = Astro.props;
---

<Tabs>
  <TabItem label="Code">
    <Code lang="angular-ts" code={code ?? ''} />
  </TabItem>
  <TabItem label="Preview">
    <div class="flex flex-col items-center">
      <slot />
    </div>
  </TabItem>
</Tabs>