    "prettier-plugin-organize-attributes": "catalog:",
    "prettier-plugin-sort-json": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=18"
  }
}
