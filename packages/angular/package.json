{
  "name": "@qrcodesdk/angular",
  "version": "0.0.0",
  "engines": {
    "node": ">=20.12.0"
  },
  "description": "@qrcodesdk/angular provides standalone Angular components for rendering QR codes as SVG, PNG-backed image elements, and canvas elements.",
  "sideEffects": false,
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Dafnik",
    "email": "contact@dafnik.me",
    "url": "https://dafnik.me"
  },
  "keywords": [
    "typescript",
    "types",
    "qr-code",
    "qrcode",
    "qr",
    "code",
    "esm",
    "modules",
    "module"
  ],
  "homepage": "https://qrcodesdk.dev/libs/angular",
  "repository": {
    "type": "git",
    "url": "git@github.com:Dafnik/qrcodesdk.git",
    "directory": "packages/angular"
  },
  "bugs": {
    "url": "https://github.com/Dafnik/qrcodesdk/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/Dafnik"
    },
    {
      "type": "liberapay",
      "url": "https://liberapay.com/Dafnik"
    }
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist/angular",
    "provenance": true
  },
  "scripts": {
    "ng": "ng",
    "build": "ng build",
    "postbuild": "cp ../../LICENSE dist/angular",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch false",
    "check-types": "ng build && tsc -p tsconfig.spec.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rm -rf .turbo dist .angular"
  },
  "peerDependencies": {
    "@qrcodesdk/core": "workspace:^",
    "@qrcodesdk/browser": "workspace:^",
    "@angular/common": "^22.0.0",
    "@angular/core": "^22.0.0",
    "rxjs": "^7.0.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "catalog:",
    "@angular/cli": "catalog:",
    "@angular/common": "catalog:",
    "@angular/compiler": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@angular/core": "catalog:",
    "@angular/platform-browser": "catalog:",
    "@qrcodesdk/browser": "workspace:*",
    "@qrcodesdk/core": "workspace:*",
    "@repo/core-testing": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "angular-eslint": "22.0.0",
    "jsdom": "catalog:",
    "ng-packagr": "22.0.0",
    "rxjs": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
