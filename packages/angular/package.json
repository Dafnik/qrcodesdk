{
  "name": "@qrcodesdk/angular",
  "version": "0.0.0",
  "description": "Placeholder Angular adapter package for QRCodeSDK.",
  "author": "Dafnik",
  "license": "MIT",
  "homepage": "https://github.com/Dafnik/qrcodesdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dafnik/qrcodesdk.git",
    "directory": "packages/angular"
  },
  "bugs": {
    "url": "https://github.com/Dafnik/qrcodesdk/issues"
  },
  "main": "./dist/angular/fesm2022/qrcodesdk-angular.mjs",
  "types": "./dist/angular/types/qrcodesdk-angular.d.ts",
  "exports": {
    ".": {
      "types": "./dist/angular/types/qrcodesdk-angular.d.ts",
      "default": "./dist/angular/fesm2022/qrcodesdk-angular.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "ng": "ng",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch false",
    "check-types": "ng build",
    "lint": "eslint projects --max-warnings 0",
    "clean": "rm -rf .turbo dist .angular"
  },
  "private": true,
  "peerDependencies": {
    "@qrcodesdk/core": "workspace:*",
    "@qrcodesdk/browser": "workspace:*",
    "@angular/common": "catalog:",
    "@angular/core": "catalog:",
    "@angular/forms": "catalog:",
    "@angular/platform-browser": "catalog:",
    "@angular/router": "catalog:",
    "rxjs": "catalog:"
  },
  "dependencies": {
    "tslib": "catalog:"
  },
  "devDependencies": {
    "@angular/build": "catalog:",
    "@angular/cli": "catalog:",
    "@angular/common": "catalog:",
    "@angular/compiler": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@angular/core": "catalog:",
    "@angular/forms": "catalog:",
    "@angular/platform-browser": "catalog:",
    "@angular/router": "catalog:",
    "@qrcodesdk/browser": "workspace:*",
    "@qrcodesdk/core": "workspace:*",
    "@repo/core-testing": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "angular-eslint": "22.0.0",
    "jsdom": "catalog:",
    "ng-packagr": "22.0.0",
    "rxjs": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
