{
  "name": "@qrcodesdk/browser",
  "type": "module",
  "version": "0.0.0",
  "description": "@qrcodesdk/browser adds renderers that depend on browser DOM APIs. Use it with `@qrcodesdk/core` when your output should be an element created in the browser or a browser-triggered download.",
  "sideEffects": false,
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Dafnik",
    "email": "contact@dafnik.me",
    "url": "https://dafnik.me"
  },
  "keywords": [
    "typescript",
    "types",
    "qr-code",
    "qrcode",
    "qr",
    "code",
    "esm",
    "modules",
    "module",
    "browser"
  ],
  "homepage": "https://qrcodesdk.dev/libs/browser",
  "repository": {
    "type": "git",
    "url": "git@github.com:Dafnik/qrcodesdk.git",
    "directory": "packages/browser"
  },
  "bugs": {
    "url": "https://github.com/Dafnik/qrcodesdk/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/Dafnik"
    },
    {
      "type": "liberapay",
      "url": "https://liberapay.com/Dafnik"
    }
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "test": "vitest --watch false",
    "check-types": "tsc --noEmit",
    "lint": "eslint src tests --max-warnings 0",
    "clean": "rm -rf .turbo dist",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@qrcodesdk/core": "workspace:*"
  },
  "devDependencies": {
    "@qrcodesdk/core": "workspace:*",
    "@repo/core-testing": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@typescript/native-preview": "catalog:",
    "@vitest/browser-playwright": "4.1.9",
    "jsqr": "catalog:",
    "playwright": "1.59.1",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
