{
  "name": "@repo/core-testing",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "test": "vitest --watch false",
    "check-types": "tsc --noEmit && tsgo -p tsconfig.spec.json",
    "lint": "eslint src tests --max-warnings 0",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@qrcodesdk/core": "workspace:*"
  },
  "devDependencies": {
    "@types/qrcode": "1.5.6",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "qrcode": "1.5.4",
    "qrcode-generator": "2.0.4",
    "jsqr": "catalog:",
    "sharp": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
