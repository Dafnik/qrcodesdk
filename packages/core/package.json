{
  "name": "@qrcodesdk/core",
  "type": "module",
  "version": "0.0.0",
  "engines": {
    "node": ">=20.12.0"
  },
  "description": "@qrcodesdk/core is the foundation of QRCodeSDK. It turns data into a QR code matrix and lets renderers decide how that matrix becomes SVG, terminal text, PNG, DOM output, or any custom format.",
  "sideEffects": false,
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Dafnik",
    "email": "contact@dafnik.me",
    "url": "https://dafnik.me"
  },
  "keywords": [
    "typescript",
    "types",
    "qr-code",
    "qrcode",
    "qr",
    "code",
    "esm",
    "modules",
    "module"
  ],
  "homepage": "https://qrcodesdk.dev/libs/core",
  "repository": {
    "type": "git",
    "url": "git@github.com:Dafnik/qrcodesdk.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Dafnik/qrcodesdk/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/Dafnik"
    },
    {
      "type": "liberapay",
      "url": "https://liberapay.com/Dafnik"
    }
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "test": "vitest --watch false",
    "test:coverage:raw": "vitest --coverage --watch false",
    "check-types": "tsc --noEmit && tsc -p tsconfig.spec.json",
    "lint": "eslint src tests --max-warnings 0",
    "clean": "rm -rf .turbo dist",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
