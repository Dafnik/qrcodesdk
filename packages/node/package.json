{
  "name": "@qrcodesdk/node",
  "type": "module",
  "version": "0.0.0",
  "engines": {
    "node": ">=20.12.0"
  },
  "description": "@qrcodesdk/node adds renderers that depend on Node.js APIs or server-side packages. Use it with `@qrcodesdk/core` when your output needs to be PNG bytes.",
  "sideEffects": false,
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Dafnik",
    "email": "contact@dafnik.me",
    "url": "https://dafnik.me"
  },
  "keywords": [
    "typescript",
    "types",
    "qr-code",
    "qrcode",
    "qr",
    "code",
    "esm",
    "modules",
    "module",
    "node"
  ],
  "homepage": "https://qrcodesdk.dev/libs/node",
  "repository": {
    "type": "git",
    "url": "git@github.com:Dafnik/qrcodesdk.git",
    "directory": "packages/node"
  },
  "bugs": {
    "url": "https://github.com/Dafnik/qrcodesdk/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/Dafnik"
    },
    {
      "type": "liberapay",
      "url": "https://liberapay.com/Dafnik"
    }
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "test": "vitest --watch false",
    "check-types": "tsc --noEmit && tsc -p tsconfig.spec.json",
    "lint": "eslint src tests --max-warnings 0",
    "clean": "rm -rf .turbo dist",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@qrcodesdk/core": "workspace:^"
  },
  "dependencies": {
    "pngjs": "7.0.0"
  },
  "devDependencies": {
    "@qrcodesdk/core": "workspace:*",
    "@repo/core-testing": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/pngjs": "6.0.5",
    "jsqr": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
