{
  "name": "@qrcodesdk/node",
  "type": "module",
  "version": "0.0.0",
  "description": "Node.js renderers for QRCodeSDK.",
  "author": "Dafnik",
  "license": "MIT",
  "homepage": "https://github.com/Dafnik/qrcodesdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dafnik/qrcodesdk.git",
    "directory": "packages/node"
  },
  "bugs": {
    "url": "https://github.com/Dafnik/qrcodesdk/issues"
  },
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "test": "vitest",
    "check-types": "tsc --noEmit",
    "release": "bumpp",
    "lint": "eslint src tests --max-warnings 0",
    "clean": "rm -rf .turbo dist",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@qrcodesdk/core": "workspace:*"
  },
  "dependencies": {
    "pngjs": "catalog:"
  },
  "devDependencies": {
    "@repo/core-testing": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/pngjs": "catalog:",
    "@typescript/native-preview": "catalog:",
    "bumpp": "catalog:",
    "jsqr": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
