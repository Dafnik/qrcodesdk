{
  "name": "@qrcodesdk/react",
  "type": "module",
  "version": "0.0.0",
  "engines": {
    "node": ">=20.12.0"
  },
  "description": "@qrcodesdk/react provides React components for rendering QR codes as SVG, PNG-backed image elements, and canvas elements.",
  "sideEffects": false,
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Dafnik",
    "email": "contact@dafnik.me",
    "url": "https://dafnik.me"
  },
  "keywords": [
    "typescript",
    "types",
    "qr-code",
    "qrcode",
    "qr",
    "code",
    "esm",
    "modules",
    "module",
    "react",
    "tsx",
    "jsx"
  ],
  "homepage": "https://qrcodesdk.dev/libs/react",
  "repository": {
    "type": "git",
    "url": "git@github.com:Dafnik/qrcodesdk.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/Dafnik/qrcodesdk/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/Dafnik"
    },
    {
      "type": "liberapay",
      "url": "https://liberapay.com/Dafnik"
    }
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "test": "vitest --watch false",
    "test:coverage:raw": "vitest --coverage --watch false",
    "check-types": "tsc --noEmit",
    "lint": "eslint src tests --max-warnings 0",
    "clean": "rm -rf .turbo dist",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@qrcodesdk/browser": "workspace:^",
    "@qrcodesdk/core": "workspace:^",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@qrcodesdk/browser": "workspace:*",
    "@qrcodesdk/core": "workspace:*",
    "@repo/core-testing": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
