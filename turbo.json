{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": [
    "ASTRO_CACHE_DIR",
    "UPDATE_PNG_SNAPSHOTS",
    "UPDATE_SVG_SNAPSHOTS",
    "UPDATE_TEXT_SNAPSHOTS",
    "VITE_CACHE_DIR"
  ],
  "tasks": {
    "//#cspell": {
      "cache": false
    },
    "//#format:check": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", "!.turbo/**", "!.astro-cache/**"]
    },
    "check": {
      "cache": false,
      "dependsOn": ["//#format:check", "//#cspell", "^build", "^test", "^lint"]
    },
    "check-types": {
      "dependsOn": ["^build", "^check-types"]
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build", "^test"]
    }
  },
  "ui": "tui"
}
